{
  "name": "voicebridge-desktop",
  "version": "1.0.0",
  "type": "module",
  "description": "VoiceBridge Desktop — Real-time voice translation with OS-level virtual microphone",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron dist/main/main.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.15.0",
    "electron": "^33.0.0",
    "preact": "^10.25.0",
    "lucide-static": "^0.460.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^3.23.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "@preact/preset-vite": "^2.9.0"
  }
}
