# VoiceBridge — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Demo Mode (Optional) ────────────────────────────────────
# Embedded API keys for demo mode so users can try without their own keys.
# Rate-limited to 5 min voice time per 24h per install.
# Leave empty to require users to enter their own keys.

VITE_DEMO_KEY_ENABLED=false

# ElevenLabs — used for STT (Scribe) and TTS (voice cloning)
VITE_DEMO_ELEVENLABS_KEY=

# LLM provider for translation: openai | anthropic | openrouter
VITE_DEMO_LLM_PROVIDER=openrouter

# LLM API key (OpenAI, Anthropic, or OpenRouter key depending on provider above)
VITE_DEMO_LLM_KEY=

# OpenRouter model slug (only used when provider is openrouter)
# Examples: openai/gpt-4o, anthropic/claude-sonnet-4, google/gemini-2.5-flash
VITE_DEMO_OPENROUTER_MODEL=openai/gpt-4o

# ── Demo Limits ──────────────────────────────────────────────
# Set to true to disable the voice-time limit entirely (unlimited demo)
VITE_DEMO_UNLIMITED=false

# Voice-time limit in seconds (only used when VITE_DEMO_UNLIMITED=false)
VITE_DEMO_VOICE_LIMIT_SECONDS=300
VITE_VERSION=1.0.0

# ── Build ────────────────────────────────────────────────────